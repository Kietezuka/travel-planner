# Generate a secret with: `openssl rand -base64 32`
NEXTAUTH_SECRET=
# Set this to your application's public URL in production.
NEXTAUTH_URL=http://localhost:3000

# Turso (libSQL) database. Get these from the Turso CLI:
#   turso db show <db> --url        -> TURSO_DATABASE_URL
#   turso db tokens create <db>     -> TURSO_AUTH_TOKEN
# Leave both empty for local dev — the app falls back to a file:local.db SQLite file.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
